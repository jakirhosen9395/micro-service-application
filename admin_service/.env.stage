# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
ADMIN_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ADMIN_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ADMIN_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
ADMIN_CORS_ALLOW_CREDENTIALS=true
ADMIN_CORS_MAX_AGE_SECONDS=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
ADMIN_SECURITY_REQUIRE_HTTPS=false
ADMIN_SECURITY_SECURE_COOKIES=true
ADMIN_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
# ------------------------------------------------------------------------------
ADMIN_ACCESS_GRANT_DEFAULT_TTL_DAYS=30
ADMIN_DEFAULT_ADMIN_SOURCE=auth_service
