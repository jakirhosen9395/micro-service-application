REPORT_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
REPORT_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
REPORT_CORS_ALLOW_CREDENTIALS=true
REPORT_CORS_MAX_AGE_SECONDS=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
REPORT_SECURITY_REQUIRE_HTTPS=false
REPORT_SECURITY_SECURE_COOKIES=false
REPORT_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
# ------------------------------------------------------------------------------
REPORT_BULLMQ_QUEUE_NAME=report-generation
REPORT_WORKER_CONCURRENCY=3
REPORT_QUEUE_REMOVE_ON_COMPLETE_AGE_SECONDS=86400
REPORT_QUEUE_REMOVE_ON_FAIL_AGE_SECONDS=604800
REPORT_QUEUE_JOB_TIMEOUT_MS=300000
REPORT_GENERATION_MAX_ROWS=100000
REPORT_PREVIEW_MAX_BYTES=1048576
REPORT_DOWNLOAD_CONTENT_DISPOSITION=attachment
REPORT_WORKER_SHUTDOWN_GRACE_MS=30000
