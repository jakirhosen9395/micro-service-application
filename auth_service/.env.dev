# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
AUTH_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
AUTH_CORS_ALLOW_CREDENTIALS=true
AUTH_CORS_MAX_AGE_SECONDS=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
AUTH_SECURITY_REQUIRE_HTTPS=false
AUTH_SECURITY_SECURE_COOKIES=false
AUTH_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
