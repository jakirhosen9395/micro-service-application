# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
AUTH_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
AUTH_CORS_ALLOW_CREDENTIALS=true
AUTH_CORS_MAX_AGE_SECONDS=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
AUTH_SECURITY_REQUIRE_HTTPS=true
AUTH_SECURITY_SECURE_COOKIES=true
AUTH_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
# ------------------------------------------------------------------------------
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_PASSWORD=admin123
AUTH_DEFAULT_ADMIN_EMAIL=admin@auth_service.local
AUTH_DEFAULT_ADMIN_FULL_NAME=Default Administrator
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SPECIAL=false
