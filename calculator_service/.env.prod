# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CALC_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CALC_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CALC_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
CALC_CORS_ALLOW_CREDENTIALS=true
CALC_CORS_MAX_AGE_SECONDS=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
CALC_SECURITY_REQUIRE_HTTPS=false
CALC_SECURITY_SECURE_COOKIES=false
CALC_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
# ------------------------------------------------------------------------------
CALC_FLYWAY_SCHEMA_HISTORY_TABLE=calculator_service_flyway_schema_history
CALC_MAX_EXPRESSION_LENGTH=512
CALC_HISTORY_DEFAULT_LIMIT=50
CALC_HISTORY_MAX_LIMIT=100
