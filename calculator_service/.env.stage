# ------------------------------------------------------------------------------
# Kafka
# ------------------------------------------------------------------------------
CALC_KAFKA_BOOTSTRAP_SERVERS=192.168.56.200:9092
CALC_KAFKA_EVENTS_TOPIC=calculator.events
CALC_KAFKA_DEAD_LETTER_TOPIC=calculator.dead-letter
CALC_KAFKA_CONSUMER_GROUP=calculator_service-stage
