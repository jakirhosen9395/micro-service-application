CALC_POSTGRES_MIGRATION_MODE=auto

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
CALC_REDIS_HOST=192.168.56.200
CALC_REDIS_PORT=6379
CALC_REDIS_PASSWORD=rlCeHk6SR2xbSCpthWX0MmC4ieBsKCoX
