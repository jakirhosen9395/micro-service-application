CALC_S3_REGION=us-east-1
CALC_S3_FORCE_PATH_STYLE=true
CALC_S3_BUCKET=microservice
CALC_S3_AUDIT_PREFIX=calculator_service/stage
CALC_S3_REPORT_PREFIX=report_service/stage

# ------------------------------------------------------------------------------
