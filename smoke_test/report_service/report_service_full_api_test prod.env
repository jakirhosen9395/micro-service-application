# ==============================================================================
# report_service full API + integration test env
# ==============================================================================

# ------------------------------------------------------------------------------
# Service URLs
# Use matching environments together:
#   dev:   AUTH 6060, CALC 2020, ADMIN 1010, USER 4040, REPORT 5050, TODO 3030
#   stage: AUTH 6061, CALC 2021, ADMIN 1011, USER 4041, REPORT 5051, TODO 3031
#   prod:  AUTH 6062, CALC 2022, ADMIN 1012, USER 4042, REPORT 5052, TODO 3032
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://52.66.197.225:1012
AUTH_BASE_URL=http://52.66.197.225:6062
USER_BASE_URL=http://52.66.197.225:4042
CALC_BASE_URL=http://52.66.197.225:2022
TODO_BASE_URL=http://52.66.197.225:3032
REPORT_BASE_URL=http://52.66.197.225:5052

# ------------------------------------------------------------------------------
# Forwarded protocol headers
# Use https for stage/prod if the service env has *_SECURITY_REQUIRE_HTTPS=true.
# Leave empty or http for dev.
# ------------------------------------------------------------------------------
REPORT_FORWARDED_PROTO=
AUTH_FORWARDED_PROTO=
CALCULATOR_FORWARDED_PROTO=
TODO_FORWARDED_PROTO=
ADMIN_FORWARDED_PROTO=
USER_FORWARDED_PROTO=

# ------------------------------------------------------------------------------
# Auth credentials and generated test identities
# ------------------------------------------------------------------------------
REPORT_TEST_ADMIN_USERNAME=admin
REPORT_TEST_ADMIN_PASSWORD=admin123
REPORT_TEST_PASSWORD=Test1234!Aa
REPORT_TEST_SECOND_PASSWORD=Test1234!Aa
REPORT_TEST_CREATE_USER=1
REPORT_TEST_CREATE_SECOND_USER=1
REPORT_TEST_AUTH_LOGIN_PATH=/v1/signin

# Optional: provide pre-issued tokens instead of creating/signing in users.
REPORT_TEST_ACCESS_TOKEN=
REPORT_TEST_ADMIN_TOKEN=
REPORT_TEST_SECOND_TOKEN=

# ------------------------------------------------------------------------------
# Test behavior
# ------------------------------------------------------------------------------
REPORT_TEST_TIMEOUT=20
REPORT_TEST_RETRIES=2
REPORT_TEST_RETRY_DELAY_SECONDS=2
REPORT_TEST_VERBOSE=0
REPORT_TEST_SAVE_RESPONSES=0
REPORT_TEST_STRICT_PUBLIC_ROUTES=1
REPORT_TEST_REQUIRED_CODE_COVERAGE=1
REPORT_TEST_WAIT_COMPLETED=0
REPORT_TEST_COMPLETION_RETRIES=24
REPORT_TEST_COMPLETION_DELAY_SECONDS=5

# ------------------------------------------------------------------------------
# Cross-service seeding and projection checks
# ------------------------------------------------------------------------------
REPORT_TEST_SEED_CALCULATOR=1
REPORT_TEST_SEED_TODO=1
REPORT_TEST_CHECK_ADMIN=1
REPORT_TEST_CHECK_USER=1
REPORT_TEST_MUTATE=0

# ------------------------------------------------------------------------------
# Report feature modes
# canonical-disabled: templates/schedules write APIs should return 501.
# enabled: templates/schedules write APIs are expected to work.
# auto: accepts either implemented or disabled behavior.
# ------------------------------------------------------------------------------
REPORT_TEST_TEMPLATE_MODE=auto
REPORT_TEST_SCHEDULE_MODE=auto

# ------------------------------------------------------------------------------
# Report payload defaults
# ------------------------------------------------------------------------------
REPORT_TEST_DATE_FROM=2026-05-01
REPORT_TEST_DATE_TO=2026-05-09
REPORT_TEST_TIMEZONE=Asia/Dhaka
REPORT_TEST_LOCALE=en
