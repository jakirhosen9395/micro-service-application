# ==============================================================================
# User Service full API test environment
# ==============================================================================

# ------------------------------------------------------------------------------
# Service URLs
# Use matching environments together:
#   dev:   AUTH 6060, CALC 2020, ADMIN 1010, USER 4040, REPORT 5050, TODO 3030
#   stage: AUTH 6061, CALC 2021, ADMIN 1011, USER 4041, REPORT 5051, TODO 3031
#   prod:  AUTH 6062, CALC 2022, ADMIN 1012, USER 4042, REPORT 5052, TODO 3032
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://3.108.225.164:1011
AUTH_BASE_URL=http://3.108.225.164:6061
USER_BASE_URL=http://3.108.225.164:4041
CALC_BASE_URL=http://3.108.225.164:2021
TODO_BASE_URL=http://3.108.225.164:3031
REPORT_BASE_URL=http://3.108.225.164:5051

# ------------------------------------------------------------------------------
# Forwarded proto
# For local stage/prod testing over HTTP host ports, set these to https.
# For dev, leave blank unless the service enforces HTTPS.
# ------------------------------------------------------------------------------
USER_FORWARDED_PROTO=
AUTH_FORWARDED_PROTO=
CALCULATOR_FORWARDED_PROTO=
TODO_FORWARDED_PROTO=
ADMIN_FORWARDED_PROTO=
REPORT_FORWARDED_PROTO=
    
# ------------------------------------------------------------------------------
# Auth users
# If USER_TEST_ACCESS_TOKEN is blank, the script signs up/signs in a generated user.
# If USER_TEST_SECOND_TOKEN is blank, the script creates a generated second user.
# If USER_TEST_ADMIN_TOKEN is blank, the script signs in the bootstrap admin.
# ------------------------------------------------------------------------------
USER_TEST_CREATE_USER=1
USER_TEST_CREATE_SECOND_USER=1
USER_TEST_USERNAME=
USER_TEST_EMAIL=
USER_TEST_PASSWORD=Test1234!Aa
USER_TEST_SECOND_USERNAME=
USER_TEST_SECOND_EMAIL=
USER_TEST_SECOND_PASSWORD=Test1234!Aa
USER_TEST_ACCESS_TOKEN=
USER_TEST_SECOND_TOKEN=
USER_TEST_ADMIN_TOKEN=
USER_TEST_ADMIN_USERNAME=admin
USER_TEST_ADMIN_PASSWORD=admin123
USER_TEST_AUTH_LOGIN_PATH=/v1/signin

# ------------------------------------------------------------------------------
# Test behavior
# ------------------------------------------------------------------------------
USER_TEST_TIMEOUT=20
USER_TEST_RETRIES=2
USER_TEST_RETRY_DELAY_SECONDS=2
USER_TEST_VERBOSE=0
USER_TEST_SAVE_RESPONSES=0
USER_TEST_MUTATE=1
USER_TEST_SEED_CALCULATOR=1
USER_TEST_SEED_TODO=1
USER_TEST_SEED_REPORT=1
USER_TEST_STRICT_PUBLIC_ROUTES=1
USER_TEST_EXPECT_EXTENDED_USER_ENDPOINTS=1
USER_TEST_REQUIRED_CODE_COVERAGE=1
USER_TEST_ACCESS_REQUEST_TTL_DAYS=14
