# ==============================================================================
# calculator_service full API test environment
# Copy this file to calculator_service_full_api_test.env and edit values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Service URLs
# Use matching environments together:
#   dev:   AUTH 6060, CALC 2020, ADMIN 1010, USER 4040, REPORT 5050, TODO 3030
#   stage: AUTH 6061, CALC 2021, ADMIN 1011, USER 4041, REPORT 5051, TODO 3031
#   prod:  AUTH 6062, CALC 2022, ADMIN 1012, USER 4042, REPORT 5052, TODO 3032
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://52.66.223.53:1011
AUTH_BASE_URL=http://52.66.223.53:6061
USER_BASE_URL=http://52.66.223.53:4041
CALC_BASE_URL=http://52.66.223.53:2021
TODO_BASE_URL=http://52.66.223.53:3031
REPORT_BASE_URL=http://52.66.223.53:5051

# ------------------------------------------------------------------------------
# Forwarded proto headers
# For stage/prod over local HTTP ports, set these to https if services enforce HTTPS.
# Leave blank for dev if HTTPS enforcement is disabled.
# ------------------------------------------------------------------------------
CALCULATOR_FORWARDED_PROTO=
AUTH_FORWARDED_PROTO=
ADMIN_FORWARDED_PROTO=
USER_FORWARDED_PROTO=
REPORT_FORWARDED_PROTO=

# ------------------------------------------------------------------------------
# Auth credentials
# Bootstrap admin must be an approved admin in auth_service.
# ------------------------------------------------------------------------------
AUTH_TEST_ADMIN_USERNAME=admin
AUTH_TEST_ADMIN_PASSWORD=admin123
AUTH_TEST_USER_PASSWORD=Test1234!Aa
AUTH_TEST_SECOND_USER_PASSWORD=Other1234!Aa

# ------------------------------------------------------------------------------
# Test behavior
# ------------------------------------------------------------------------------
CALCULATOR_TEST_TIMEOUT=25
CALCULATOR_TEST_VERBOSE=0
CALCULATOR_TEST_TENANT=dev
CALCULATOR_TEST_EVENT_SETTLE_SECONDS=3

# Optional downstream checks. Keep 1 when the corresponding service is running.
CALCULATOR_TEST_ENABLE_ADMIN_CHECKS=1
CALCULATOR_TEST_ENABLE_USER_CHECKS=1
CALCULATOR_TEST_ENABLE_REPORT_CHECKS=1

# Mutation checks only affect generated test users/calculations.
# DELETE /v1/calculator/history is always run for the generated user unless disabled.
CALCULATOR_TEST_ENABLE_DELETE_HISTORY=1

# Report type used for report_service integration check.
CALCULATOR_TEST_REPORT_TYPE=calculator_history_report
CALCULATOR_TEST_REPORT_FORMAT=pdf
