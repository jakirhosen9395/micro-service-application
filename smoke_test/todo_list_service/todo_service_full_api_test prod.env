# Todo Service full API/integration test configuration
# Copy this file to todo_service_full_api_test.env and edit values for your environment.

# ------------------------------------------------------------------------------
# Service URLs
# Use matching environments together:
#   dev:   AUTH 6060, CALC 2020, ADMIN 1010, USER 4040, REPORT 5050, TODO 3030
#   stage: AUTH 6061, CALC 2021, ADMIN 1011, USER 4041, REPORT 5051, TODO 3031
#   prod:  AUTH 6062, CALC 2022, ADMIN 1012, USER 4042, REPORT 5052, TODO 3032
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://3.108.225.164:1012
AUTH_BASE_URL=http://3.108.225.164:6062
USER_BASE_URL=http://3.108.225.164:4042
CALC_BASE_URL=http://3.108.225.164:2022
TODO_BASE_URL=http://3.108.225.164:3032
REPORT_BASE_URL=http://3.108.225.164:5052

# ------------------------------------------------------------------------------
# Auth credentials
# ------------------------------------------------------------------------------
TODO_TEST_ADMIN_USERNAME=admin
TODO_TEST_ADMIN_PASSWORD=admin123
TODO_TEST_USER_PASSWORD=Test1234!Aa
TODO_TEST_SECOND_USER_PASSWORD=Test1234!Aa

# ------------------------------------------------------------------------------
# Test behavior
# ------------------------------------------------------------------------------
TODO_TEST_TENANT=dev
TODO_TEST_TIMEOUT=25
TODO_TEST_VERBOSE=0
TODO_TEST_RUN_DOWNSTREAM=1
TODO_TEST_RUN_MUTATIONS=1
TODO_TEST_EVENT_WAIT_SECONDS=3
TODO_TEST_REPORT_FORMAT=pdf
TODO_TEST_REPORT_TYPE=

# ------------------------------------------------------------------------------
# X-Forwarded-Proto support
# Use empty value for normal HTTP dev services.
# Use https for stage/prod when services enforce HTTPS behind a proxy.
# ------------------------------------------------------------------------------
TODO_FORWARDED_PROTO=
AUTH_FORWARDED_PROTO=
ADMIN_FORWARDED_PROTO=
USER_FORWARDED_PROTO=
REPORT_FORWARDED_PROTO=
