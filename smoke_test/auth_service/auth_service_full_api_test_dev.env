# ==============================================================================
# Auth service full API and integration test config
# Copy this file to auth_service_full_api_test.env and edit values for your VM.
# ==============================================================================

# ------------------------------------------------------------------------------
# Service URLs
# Use matching environments together:
#   dev:   AUTH 6060, CALC 2020, ADMIN 1010, USER 4040, REPORT 5050, TODO 3030
#   stage: AUTH 6061, CALC 2021, ADMIN 1011, USER 4041, REPORT 5051, TODO 3031
#   prod:  AUTH 6062, CALC 2022, ADMIN 1012, USER 4042, REPORT 5052, TODO 3032
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://3.108.225.164:1010
AUTH_BASE_URL=http://3.108.225.164:6060
USER_BASE_URL=http://3.108.225.164:4041
CALC_BASE_URL=http://3.108.225.164:2021
TODO_BASE_URL=http://3.108.225.164:3031
REPORT_BASE_URL=http://3.108.225.164:5051

# ------------------------------------------------------------------------------
# Expected Auth tenant for JWT claim validation
# dev=dev, stage=stage, prod=prod
# ------------------------------------------------------------------------------
AUTH_TEST_TENANT=dev

# ------------------------------------------------------------------------------
# Bootstrap approved admin credentials from auth_service
# ------------------------------------------------------------------------------
AUTH_TEST_ADMIN_USERNAME=admin
AUTH_TEST_ADMIN_PASSWORD=admin123

# ------------------------------------------------------------------------------
# Test runtime behavior
# ------------------------------------------------------------------------------
AUTH_TEST_TIMEOUT=25
AUTH_TEST_VERBOSE=0
AUTH_TEST_SAVE_RESPONSES=0
AUTH_TEST_RESPONSE_DIR=./auth_test_responses
AUTH_TEST_REQUIRE_HEALTH_OK=1

# If your auth_service publicly exposes /openapi.json set this to 1.
# Canonical strict contract expects /docs public and /openapi.json rejected.
AUTH_TEST_EXPECT_OPENAPI_PUBLIC=0

# Password reset token behavior:
#   auto = reset token optional; useful for stage/prod where reset token may not be returned
#   1    = require reset_token in forgot-password response; useful for dev
AUTH_TEST_EXPECT_RESET_TOKEN=auto

# ------------------------------------------------------------------------------
# Generated user/password defaults
# The script generates unique usernames/emails automatically unless you override them.
# ------------------------------------------------------------------------------
AUTH_TEST_INITIAL_PASSWORD=Test1234!Aa
AUTH_TEST_RESET_PASSWORD=Reset1234!Aa
AUTH_TEST_CHANGED_PASSWORD=Changed1234!Aa
AUTH_TEST_PENDING_ADMIN_PASSWORD=Admin1234!Aa
# AUTH_TEST_NORMAL_USERNAME=
# AUTH_TEST_NORMAL_EMAIL=
# AUTH_TEST_PENDING_ADMIN_USERNAME=
# AUTH_TEST_PENDING_ADMIN_EMAIL=
# AUTH_TEST_REJECT_ADMIN_USERNAME=
# AUTH_TEST_REJECT_ADMIN_EMAIL=

# ------------------------------------------------------------------------------
# Downstream integration checks
# These verify auth_service JWT compatibility across other services.
# Set AUTH_TEST_DOWNSTREAM_MUTATE=1 to create calculator/todo/report records.
# ------------------------------------------------------------------------------
AUTH_TEST_DOWNSTREAM_ENABLED=1
AUTH_TEST_DOWNSTREAM_MUTATE=0
AUTH_TEST_PROJECTION_RETRIES=12
AUTH_TEST_PROJECTION_SLEEP_SECONDS=2

# ------------------------------------------------------------------------------
# Forwarded proto headers for local HTTP testing when a service enforces HTTPS.
# For stage/prod over local HTTP host ports, set relevant values to https.
# For dev, leave these blank unless your dev service also requires HTTPS.
# ------------------------------------------------------------------------------
AUTH_TEST_AUTH_FORWARDED_PROTO=
AUTH_TEST_ADMIN_FORWARDED_PROTO=
AUTH_TEST_USER_FORWARDED_PROTO=
AUTH_TEST_CALCULATOR_FORWARDED_PROTO=
AUTH_TEST_TODO_FORWARDED_PROTO=
AUTH_TEST_REPORT_FORWARDED_PROTO=
