# Admin Service Full API Test Configuration
# Copy to admin_service_full_api_test.env and edit values for your environment.

# ------------------------------------------------------------------------------
# Service base URLs. Use matching environments.
# dev:   admin 1010 + auth 6060
# stage: admin 1011 + auth 6061
# prod:  admin 1012 + auth 6062
# ------------------------------------------------------------------------------
ADMIN_BASE_URL=http://192.168.56.100:1010
AUTH_BASE_URL=http://192.168.56.100:6060
USER_BASE_URL=http://192.168.56.100:4040
CALC_BASE_URL=http://192.168.56.100:2020
TODO_BASE_URL=http://192.168.56.100:3030
REPORT_BASE_URL=http://192.168.56.100:5050

# ------------------------------------------------------------------------------
# Admin/auth credentials
# ------------------------------------------------------------------------------
ADMIN_TEST_AUTH_USERNAME=admin
ADMIN_TEST_AUTH_PASSWORD=admin123
ADMIN_TEST_AUTH_LOGIN_PATH=/v1/signin
ADMIN_TEST_AUTH_SIGNUP_PATH=/v1/signup

# Optional: provide tokens directly. If blank, the script signs in through auth_service.
ADMIN_TEST_ADMIN_TOKEN=
ADMIN_TEST_NORMAL_TOKEN=
ADMIN_TEST_SECOND_TOKEN=

# ------------------------------------------------------------------------------
# Test behavior
# ------------------------------------------------------------------------------
ADMIN_TEST_TIMEOUT=25
ADMIN_TEST_VERBOSE=0
ADMIN_TEST_SAVE_RESPONSES=0
ADMIN_TEST_CREATE_USERS=1
ADMIN_TEST_SEED_OTHER_SERVICES=1
ADMIN_TEST_MUTATE=0
ADMIN_TEST_STRICT=0
ADMIN_TEST_PROJECTION_WAIT_SECONDS=8

# Send X-Forwarded-Proto to admin_service. Keep https for stage/prod HTTP port tests.
ADMIN_TEST_ADMIN_FORWARDED_PROTO=https

# ------------------------------------------------------------------------------
# Generated test user defaults
# ------------------------------------------------------------------------------
ADMIN_TEST_USER_PASSWORD=Test1234!Aa
ADMIN_TEST_REPORT_FORMAT=pdf
ADMIN_TEST_REPORT_TYPE=calculator_history_report
