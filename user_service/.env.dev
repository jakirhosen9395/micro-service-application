# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
USER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
USER_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
USER_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Trace-ID,X-Correlation-ID
