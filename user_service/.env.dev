# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
USER_SECURITY_REQUIRE_HTTPS=false
USER_SECURITY_SECURE_COOKIES=false
USER_SECURITY_REQUIRE_TENANT_MATCH=true

# ------------------------------------------------------------------------------
# Service-specific settings
# Keep section even if empty. Only service-specific behavior belongs here.
# ------------------------------------------------------------------------------
USER_DEFAULT_TIMEZONE=Asia/Dhaka
USER_DEFAULT_LOCALE=en
USER_DEFAULT_THEME=dark
USER_ACCESS_REQUEST_DEFAULT_TTL_DAYS=30
USER_ACCESS_REQUEST_MAX_TTL_DAYS=90
USER_REPORT_DEFAULT_FORMAT=pdf
USER_REPORT_ALLOWED_FORMATS=pdf,csv,json,html,xlsx
